local function toCF(d) return CFrame.new(d[1],d[2],d[3],d[4],d[5],d[6],d[7],d[8],d[9],d[10],d[11],d[12]) end
local playing = true
local function playAnim()
 local char = player.Character or player.CharacterAdded:Wait()
 local hum = char:FindFirstChildOfClass('Humanoid')
 local animScript = char:FindFirstChild('Animate')
 if animScript then animScript.Disabled = true end
 local animator = nil
 if hum then
  animator = hum:FindFirstChildOfClass('Animator')
  if animator then for _,t in pairs(animator:GetPlayingAnimationTracks()) do t:Stop(0) end end
 end
 local motors = {}
 for _,v in pairs(char:GetDescendants()) do if v:IsA('Motor6D') then motors[v.Name] = v end end
 local startT = os.clock()
 local totalDur = frameData[#frameData].t
 if totalDur <= 0 then totalDur = 1 end
 local conn
 conn = RunService.Stepped:Connect(function()
  if not playing then return end
  if animator then for _,t in pairs(animator:GetPlayingAnimationTracks()) do t:Stop(0) end end
  local elapsed = os.clock() - startT
  if elapsed >= totalDur then
   elapsed = totalDur
   playing = false
  end
  local pf, nf = frameData[1], frameData[#frameData]
  for i = 1, #frameData - 1 do
   if frameData[i].t <= elapsed and frameData[i+1].t >= elapsed then pf = frameData[i] nf = frameData[i+1] break end
  end
  local span = nf.t - pf.t
  local alpha = span > 0 and (elapsed - pf.t) / span or 0
  for mn, motor in pairs(motors) do
   local pd, nd = pf.bones[mn], nf.bones[mn]
   if pd and nd then motor.Transform = toCF(pd):Lerp(toCF(nd), alpha)
   elseif pd then motor.Transform = toCF(pd)
   elseif nd then motor.Transform = toCF(nd) end
  end
  if not playing then
   conn:Disconnect()
   for mn, motor in pairs(motors) do motor.Transform = CFrame.new() end
   if animScript then animScript.Disabled = false end
  end
 end)
end
playAnim()
return nil